                kind
                name
                inputFields {
                  name
                  description
                  defaultValue
                  isDeprecated
                  deprecationReason
                  type { kind name ofType { kind name } }
                }
              }
            }
        $$)
    );
                 jsonb_pretty                  
-----------------------------------------------
