        graphql.resolve($$
            {
              __type(name: "OrderByDirection") {
                kind
                name
                description
                enumValues {
                  name
                  description
                  isDeprecated
                  deprecationReason
                }
              }
            }
        $$)
    );
                            jsonb_pretty                             
---------------------------------------------------------------------
