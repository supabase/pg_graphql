     "data": {                                +
         "__type": {                          +
             "kind": "INPUT_OBJECT",          +
             "name": "BlogInsertInput",       +
             "inputFields": [                 +
                 {                            +
                     "name": "content",       +
                     "type": {                +
                         "kind": "SCALAR",    +
                         "name": "String",    +
                         "ofType": null       +
                     },                       +
                     "description": null,     +
                     "defaultValue": null,    +
                     "isDeprecated": false,   +
                     "deprecationReason": null+
                 }                            +
             ]                                +
         }                                    +
